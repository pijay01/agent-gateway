# Server
PORT=3001

# Auth — comma-separated label:key pairs
API_KEYS=default:changeme

# Logging (off | info | debug)
LOG_LEVEL=info

# Anthropic Authentication (choose one):
# Option A: OAuth (recommended) — run POST /v1/auth/login after startup, no key needed
# Option B: API Key — set the key below
# ANTHROPIC_API_KEY=sk-ant-...

# Sessions
SESSION_IDLE_TIMEOUT_MS=0
# Docker: sessions persist to the gateway_data volume
SESSION_PERSIST_PATH=/data/sessions.json
